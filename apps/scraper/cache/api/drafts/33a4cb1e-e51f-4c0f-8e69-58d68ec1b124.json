},
"description": "fraktsioonide ettepanekuid ENPA Eesti delegatsiooni muutmiseks"
},
{
"decision": {
"code": "MUU_OTSUS",
"value": "Muu otsus"
},
"description": "Teha Riigikogu juhatusele ettepanek määrata eelnõule muudatusettepanekute esitamise tähtajaks reede, 19. mai kell 15.00"
},
{
"decision": {
"code": "KINNITADA_DOKUMENDID",
