"decision": {
"code": "VOTTA_TK_JA_LOPPHAALETUS",
"value": "Teha ettepanek võtta eelnõu täiskogu päevakorda ja viia läbi lõpphääletus"
},
"description": "juhul kui Riigikogu juhatus määrab juhtivkomisjoniks väliskomisjoni",
"plenaryAgendaDateTime": "2023-05-25T10:00:00"
},
{
"decision": {
"code": "TOETADA",
