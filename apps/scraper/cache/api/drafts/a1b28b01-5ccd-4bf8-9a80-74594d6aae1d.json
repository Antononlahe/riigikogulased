},
{
"decision": {
"code": "MUU_OTSUS",
"value": "Muu otsus"
},
"description": "Juhul, kui juhatus komisjoni eelmist ettepanekut arvestab, siis taotleda Riigikogu juhatuselt eelnõu 624 SE teise lugemise materjalide osas vastavalt RKKTS seaduse §-le 62 dokumentide kättesaadavaks tegemise tähtaja lühendamist ja määrata uueks tähtajaks ka. 13. juuni kell 16.00"
},
{
"decision": {
"code": "II_LUGEMINE_LOPETADA",
"value": "Teha ettepanek teine lugemine lõpetada"
}
},
{
"decision": {
"code": "II_LOPETATAKSE_SIIS_TK",
"value": "Kui teine lugemine lõpetatakse, teha ettepanek võtta eelnõu täiskogu päevakorda ja viia läbi lõpphääletus"
},
"plenaryAgendaDateTime": "2025-06-18T14:00:00"
}
