"committeeDecisions": [
{
"decision": {
"code": "VOTTA_TK_JA_LOPPHAALETUS",
"value": "Teha ettepanek võtta eelnõu täiskogu päevakorda ja viia läbi lõpphääletus"
},
"description": "juhul kui Riigikogu juhatus määrab juhtivkomisjoniks väliskomisjoni",
"plenaryAgendaDateTime": "2023-05-25T10:00:00"
},
{
"decision": {
"code": "TOETADA",
"value": "Toetada"
},
"description": "fraktsioonide ettepanekuid NATO PA Eesti delegatsiooni muutmiseks"
},
{
"decision": {
"code": "MUU_OTSUS",
"value": "Muu otsus"
},
"description": "Teha Riigikogu juhatusele ettepanek määrata eelnõule muudatusettepanekute esitamise tähtajaks reede, 19. mai kell 15.00"
},
{
"decision": {
"code": "KINNITADA_DOKUMENDID",
"value": "Kinnitada"
},
"description": "eelnõu tekst ja seletuskiri ning esitada eelnõu täiskogule"
},
{
"decision": {
"code": "MAARATA_JUHTKOM_ETTEKANDJAKS",
