"title": "Võlaõigusseaduse ja tarbijakaitseseaduse muutmise seadus",
"mark": 796,
"copyOrOriginal": "ORIGINAL",
"membership": 15,
"titleWithMarkAndTypeCode": "Võlaõigusseaduse ja tarbijakaitseseaduse muutmise seadus 796 SE",
