# Copy to .env and fill in. Both apps read DATABASE_URL.
# Neon example: postgres://user:pass@host.neon.tech/parteidistsipliin?sslmode=require
DATABASE_URL=

# Scraper-only knobs (safe defaults baked into apps/scraper if unset)
RIIGIKOGU_BASE_URL=https://www.riigikogu.ee
SCRAPER_USER_AGENT=parteidistsipliin-scraper/0.1 (+https://github.com/antononlahe/parteidistsipliin)
SCRAPER_REQUEST_DELAY_MS=500
