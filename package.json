{
  "name": "parteidistsipliin",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard tracking Estonian Riigikogu members' voting discipline.",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "start": "pnpm -C apps/web start",
    "lint": "pnpm -C apps/web lint",
    "typecheck": "pnpm -C apps/web typecheck",
    "test:web": "pnpm -C apps/web test",
    "scrape": "cd apps/scraper && uv run parteidistsipliin-scraper",
    "scrape:install": "cd apps/scraper && uv sync",
    "scrape:test": "cd apps/scraper && uv run pytest",
    "db:migrate": "cd apps/scraper && uv run parteidistsipliin-scraper migrate"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
